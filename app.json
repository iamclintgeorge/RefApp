{
  "expo": {
    "name": "RefApp",
    "slug": "RefApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/nlogo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
